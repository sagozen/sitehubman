{
  "expo": {
    "name": "SiteHub Man",
    "slug": "bio-cloud-native",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "biocloud",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sagozen.sitehubman",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "SiteHub needs camera access to scan QR codes on NFC cards.",
        "NFCReaderUsageDescription": "SiteHub uses NFC to encode and verify customer NFC cards.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "entitlements": {
        "com.apple.developer.nfc.readersession.formats": [
          "NDEF",
          "TAG"
        ]
      }
    },
    "android": {
      "package": "com.biocloud.nativeapp",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.NFC"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon.png",
      "name": "NFC Global",
      "shortName": "NFC Global",
      "themeColor": "#0B1220",
      "backgroundColor": "#EEF0F5",
      "display": "standalone"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-image-picker",
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SiteHub to access your camera to scan card QR codes.",
          "microphonePermission": false,
          "recordAudioAndroid": false
        }
      ],
      "react-native-nfc-manager",
      "expo-updates",
      "@sentry/react-native",
      "react-native-compressor"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/cb54673a-8b20-4939-9332-6e9f312521a5",
      "enabled": true,
      "checkAutomatically": "ON_ERROR_RECOVERY",
      "fallbackToCacheTimeout": 5000
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cb54673a-8b20-4939-9332-6e9f312521a5"
      }
    },
    "owner": "theanthean8888"
  }
}
