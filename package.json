{
  "name": "bolt-expo-starter",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--max-old-space-size=16384 expo start -c --lan",
    "start:clear": "cross-env NODE_OPTIONS=--max-old-space-size=16384 expo start -c --lan",
    "start:localhost": "cross-env NODE_OPTIONS=--max-old-space-size=16384 expo start -c --localhost",
    "start:web": "cross-env NODE_OPTIONS=--max-old-space-size=16384 expo start --web --port 8081",
    "start:web:clear": "cross-env NODE_OPTIONS=--max-old-space-size=16384 expo start -c --web --port 8081",
    "start:tunnel": "npx expo start --tunnel",
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=16384 expo start",
    "android": "cross-env NODE_OPTIONS=--max-old-space-size=16384 expo start --android",
    "ios": "cross-env NODE_OPTIONS=--max-old-space-size=16384 expo start --ios",
    "lint": "npx expo lint",
    "typecheck": "tsc --noEmit",
    "eas:build:preview": "npx eas build --platform all --profile preview",
    "eas:whoami": "npx eas whoami",
    "eas:link-backup": "powershell -ExecutionPolicy Bypass -File scripts/link-expo-backup.ps1",
    "eas:build:apk": "npx eas build --platform android --profile preview-apk",
    "eas:update:preview": "npx eas update --branch preview --message \"preview update\" --non-interactive",
    "eas:update:production": "npx eas update --branch production --message \"production update\" --non-interactive",
    "build:apk": "powershell -ExecutionPolicy Bypass -File scripts/build-test-apk.ps1",
    "eas:build:production": "npx eas build --platform all --profile production",
    "eas:build:ios:testflight": "npx eas build --platform ios --profile production",
    "eas:submit:ios:testflight": "npx eas submit --platform ios --profile production --latest",
    "test:crud": "node scripts/crud-smoke-test.mjs",
    "test:payment:sandbox": "node scripts/sandbox-payment-smoke.mjs --keep",
    "test:payment:rules": "node scripts/sandbox-payment-smoke.mjs --client-only",
    "test:security:rules": "node scripts/security-rules-check.mjs",
    "test:launch": "node scripts/launch-verification.mjs",
    "verify:launch": "node scripts/launch-verification.mjs",
    "verify:production:static": "node scripts/production-gate.mjs",
    "verify:production": "node scripts/production-gate.mjs --full",
    "deploy:rules": "node scripts/deploy-firestore-rules.mjs",
    "deploy:indexes": "node scripts/deploy-firestore-indexes.mjs",
    "deploy:payments": "node scripts/deploy-payment-functions.mjs",
    "deploy:firestore": "node scripts/deploy-firestore-rules.mjs && node scripts/deploy-firestore-indexes.mjs",
    "fix:launch": "node scripts/deploy-firestore-rules.mjs && node scripts/launch-verification.mjs",
    "backfill:company-id": "node scripts/backfill-company-id.mjs",
    "seed:demo": "node scripts/seed-demo-data.mjs seed",
    "create:super-admin": "node scripts/create-super-admin.mjs",
    "google:setup": "node scripts/print-google-setup.mjs",
    "telegram:setup": "node scripts/print-telegram-setup.mjs",
    "eas:env:checklist": "node scripts/print-eas-env-checklist.mjs",
    "eas:env:push": "node scripts/push-eas-env.mjs",
    "build:web": "cross-env NODE_OPTIONS=--max-old-space-size=16384 expo export --platform web",
    "preview:web": "npx expo serve dist",
    "restart:expo": "powershell -ExecutionPolicy Bypass -File scripts/restart-expo.ps1",
    "run": "powershell -ExecutionPolicy Bypass -File scripts/run-sitehub.ps1",
    "metro:watch": "expo start --max-workers 2",
    "metro:reset": "expo start -c"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.1",
    "@expo-google-fonts/maven-pro": "^0.4.1",
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "@sentry/react-native": "~7.2.0",
    "@solar-icons/react-native": "^1.1.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/crypto-js": "^4.2.2",
    "bcryptjs": "^3.0.2",
    "bwip-js": "^4.11.1",
    "crypto-js": "^4.2.0",
    "expo": "~54.0.35",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.11",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.24",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.11",
    "firebase": "^12.13.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-compressor": "^1.19.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-nfc-manager": "^3.17.2",
    "react-native-qrcode-svg": "^6.3.15",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "react-zlib-js": "^2.1.0",
    "whatwg-fetch": "^3.6.20"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.10",
    "cross-env": "^7.0.3",
    "eas-cli": "^16.24.1",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "firebase-tools": "^14.27.0",
    "google-auth-library": "^10.6.2",
    "typescript": "~5.9.2"
  }
}
